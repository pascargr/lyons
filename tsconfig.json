{
    "include": ["src/*"],
    "exclude": [],
    "compilerOptions": {
        "module": "esnext", 
        "moduleResolution": "node", 
        "lib": ["DOM", "ES2018", "ES2020.Intl"],
        "noEmitOnError": true,
        "noImplicitAny": true,
        "skipLibCheck": true,
        "outDir": "lib",
        "rootDir": "src",
        "strict": true,
        "strictNullChecks": true,
        "target": "ES2018",
        "composite": true,
        "declaration": true,
        "esModuleInterop": true
    }
}