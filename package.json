{
    "name": "lyons",
    "version": "0.1.3",
    "license": "MIT",
    "files": [
        "src/**/*.{ts,tsx}",
        "lib/**/*.{js,d.ts}"
    ],
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "dependencies": {
        "@jupyterlab/application": ">=4.4.0",
        "@jupyterlab/apputils": ">=4.4.0"
    },
    "devDependencies": {
        "@jupyterlab/builder": ">=4.4.0",
        "typescript": "~5.5.4"
    },
    "jupyterlab": {
        "extension": true,
        "outputDir": "lyons/labextension"
    }, 
    "scripts": {
        "build:prod": "tsc && jupyter labextension build .",
        "build:dev": "tsc --sourceMap && jupyter labextension build --development True . ",
        "clean": "rm -r lib tsconfig.tsbuildinfo lyons/labextension",
        "watch": "tsc -w --sourceMap & jupyter labextension watch ."
    }
}